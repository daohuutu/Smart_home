PORT=3000
MONGODB_URI=mongodb://localhost:27017/smart_home

# Tự động hóa
AUTO_FAN_TEMP=30
NIGHT_START_HOUR=18
NIGHT_END_HOUR=6
AUTO_AQI_THRESHOLD=1500

# TTL (ngày) — MongoDB tự xóa document cũ
SENSOR_TTL_DAYS=30
ACTIVITY_TTL_DAYS=90
ALERT_TTL_DAYS=90

# Cron dọn dữ liệu thêm (0 3 * * * = 3h sáng mỗi ngày)
CLEANUP_CRON=0 3 * * *
